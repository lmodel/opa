openpolicyagent:description a owl:DatatypeProperty ;
    rdfs:label "description" ;
    skos:definition "Markdown description of the argument.",
        "Markdown description of the built-in.",
        "Markdown description of the result." ;
    skos:inScheme openpolicyagent:builtin_metadata .

openpolicyagent:Any a owl:Class ;
    rdfs:label "Any" ;
    skos:definition "Free-form value placeholder (scalar, list, or object). Used to model source slots whose representation is heterogeneous or intentionally open (e.g. ``TypeDecl.key``, ``AuthorizationInput.body``)." ;
    skos:exactMatch linkml:Any ;
    skos:inScheme openpolicyagent:common ;
    skos:note "Single shared definition mapped to ``linkml:Any`` (per metamodel) to avoid duplicate-class collisions across imported modules.",
        "Usage is concentrated at real polymorphism boundaries: free-form HTTP payloads, bundle metadata/annotations, discriminated-union payloads, and upstream-opaque JSON Schema slots.",
        "Usage is localized (roughly 11 sites across ~60 classes); most slots remain explicitly typed rather than defaulting to ``Any``." .

openpolicyagent:BuiltinTypeKind a owl:Class ;
    rdfs:label "BuiltinTypeKind" ;
    owl:unionOf ( <https://w3id.org/lmodel/opa/BuiltinTypeKind#string> <https://w3id.org/lmodel/opa/BuiltinTypeKind#number> <https://w3id.org/lmodel/opa/BuiltinTypeKind#boolean> <https://w3id.org/lmodel/opa/BuiltinTypeKind#null> <https://w3id.org/lmodel/opa/BuiltinTypeKind#any> <https://w3id.org/lmodel/opa/BuiltinTypeKind#array> <https://w3id.org/lmodel/opa/BuiltinTypeKind#set> <https://w3id.org/lmodel/opa/BuiltinTypeKind#object> <https://w3id.org/lmodel/opa/BuiltinTypeKind#function> ) ;
    skos:definition "Kinds of value that a TypeDecl can describe." ;
    skos:inScheme openpolicyagent:capabilities ;
    linkml:permissible_values <https://w3id.org/lmodel/opa/BuiltinTypeKind#any>,
        <https://w3id.org/lmodel/opa/BuiltinTypeKind#array>,
        <https://w3id.org/lmodel/opa/BuiltinTypeKind#boolean>,
