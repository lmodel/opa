openpolicyagent:TypeDecl a owl:Class ;
    rdfs:label "TypeDecl" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom openpolicyagent:BuiltinTypeKind ;
            owl:onProperty openpolicyagent:type ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty openpolicyagent:type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty openpolicyagent:key ],
        [ a owl:Restriction ;
            owl:allValuesFrom openpolicyagent:TypeDecl ;
            owl:onProperty openpolicyagent:static ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty openpolicyagent:value ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty openpolicyagent:key ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty openpolicyagent:of ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty openpolicyagent:value ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty openpolicyagent:dynamic ],
        [ a owl:Restriction ;
            owl:allValuesFrom openpolicyagent:TypeDecl ;
            owl:onProperty openpolicyagent:of ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty openpolicyagent:static ],
        [ a owl:Restriction ;
            owl:allValuesFrom openpolicyagent:TypeDecl ;
            owl:onProperty openpolicyagent:dynamic ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty openpolicyagent:dynamic ],
        [ a owl:Restriction ;
            owl:allValuesFrom openpolicyagent:TypeDecl ;
            owl:onProperty openpolicyagent:value ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty openpolicyagent:type ],
        [ a owl:Restriction ;
            owl:allValuesFrom openpolicyagent:Any ;
            owl:onProperty openpolicyagent:key ] ;
    skos:definition """Recursive type expression used throughout Capabilities declarations.

All slots are optional because TypeDecl doubles as the structural envelope
for the various heterogeneous shapes the source JSON uses:
* ``string|number|boolean|null|function`` -- atomic; only ``type`` is set.
* ``any`` -- ``of`` is a list of alternative TypeDecls.
* ``set`` -- ``of`` holds the (single) element TypeDecl.
* ``array`` -- ``dynamic`` is the homogeneous element TypeDecl, or
  ``static`` is an ordered list describing a fixed-length tuple.
* ``object`` -- ``static`` lists named property pairs (TypeDecls with
  ``key`` and ``value`` populated); ``dynamic`` is a TypeDecl whose
  ``key``/``value`` describe additional property typing.
* Inside an ``object``'s ``dynamic`` value, the TypeDecl has only
  ``key`` and ``value`` populated -- ``type`` is absent.
""" ;
    skos:inScheme openpolicyagent:capabilities .

