openpolicyagent:ElementVersion a owl:Class ;
    rdfs:label "ElementVersion" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty openpolicyagent:name ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty openpolicyagent:major ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty openpolicyagent:patch ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty openpolicyagent:name ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty openpolicyagent:major ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty openpolicyagent:name ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty openpolicyagent:patch ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:intersectionOf ( xsd:integer [ a rdfs:Datatype ;
                                owl:onDatatype xsd:integer ;
                                owl:withRestrictions ( [ xsd:minInclusive 0 ] ) ] ) ] ;
            owl:onProperty openpolicyagent:minor ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty openpolicyagent:minor ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty openpolicyagent:minor ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:intersectionOf ( xsd:integer [ a rdfs:Datatype ;
                                owl:onDatatype xsd:integer ;
                                owl:withRestrictions ( [ xsd:minInclusive 0 ] ) ] ) ] ;
            owl:onProperty openpolicyagent:patch ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:intersectionOf ( xsd:integer [ a rdfs:Datatype ;
                                owl:onDatatype xsd:integer ;
                                owl:withRestrictions ( [ xsd:minInclusive 0 ] ) ] ) ] ;
            owl:onProperty openpolicyagent:major ] ;
    skos:definition "Semantic version triple identifying when an element was introduced." ;
    skos:inScheme openpolicyagent:version_index .

