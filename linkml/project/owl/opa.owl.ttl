openpolicyagent:BreakStmt a owl:Class ;
    rdfs:label "BreakStmt" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:integer ;
            owl:onProperty openpolicyagent:row ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:integer ;
            owl:onProperty openpolicyagent:col ],
