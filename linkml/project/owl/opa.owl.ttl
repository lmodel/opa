    skos:definition "``AssignVarStmt`` definition from upstream JSON Schema." ;
    skos:inScheme openpolicyagent:ir_plan .

openpolicyagent:BlockStmt a owl:Class ;
    rdfs:label "BlockStmt" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty openpolicyagent:row ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty openpolicyagent:row ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:integer ;
            owl:onProperty openpolicyagent:col ],
