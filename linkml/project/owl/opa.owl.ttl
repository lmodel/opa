        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty openpolicyagent:col ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty openpolicyagent:col ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:integer ;
            owl:onProperty openpolicyagent:index ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty openpolicyagent:index ] ;
    skos:definition "``BreakStmt`` definition from upstream JSON Schema." ;
    skos:inScheme openpolicyagent:ir_plan .

openpolicyagent:Builtin a owl:Class ;
    rdfs:label "Builtin" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:boolean ;
            owl:onProperty openpolicyagent:nondeterministic ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty openpolicyagent:relation ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty openpolicyagent:infix ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty openpolicyagent:infix ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:boolean ;
            owl:onProperty openpolicyagent:relation ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty openpolicyagent:deprecated ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty openpolicyagent:decl ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty openpolicyagent:name ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty openpolicyagent:nondeterministic ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty openpolicyagent:nondeterministic ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty openpolicyagent:relation ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty openpolicyagent:infix ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty openpolicyagent:decl ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty openpolicyagent:name ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty openpolicyagent:deprecated ],
