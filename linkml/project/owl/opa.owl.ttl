    rdfs:label "FeatureName" ;
    owl:unionOf ( <https://w3id.org/lmodel/opa/feature/keywords_in_refs> <https://w3id.org/lmodel/opa/feature/rego_v1> <https://w3id.org/lmodel/opa/feature/template_strings> ) ;
    skos:definition "Optional features advertised by the OPA build. The permissible values below are seeded from the upstream capabilities.json snapshot at generation time; future releases may introduce new flags." ;
    skos:inScheme openpolicyagent:capabilities ;
    linkml:permissible_values <https://w3id.org/lmodel/opa/feature/keywords_in_refs>,
        <https://w3id.org/lmodel/opa/feature/rego_v1>,
        <https://w3id.org/lmodel/opa/feature/template_strings> .

