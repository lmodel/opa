openpolicyagent:Stmt a owl:Class ;
    rdfs:label "Stmt" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty openpolicyagent:stmt ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ owl:intersectionOf ( [ owl:unionOf ( openpolicyagent:ArrayAppendStmt openpolicyagent:AssignIntStmt openpolicyagent:AssignVarOnceStmt openpolicyagent:AssignVarStmt openpolicyagent:BlockStmt openpolicyagent:BreakStmt openpolicyagent:CallDynamicStmt openpolicyagent:CallStmt openpolicyagent:DotStmt openpolicyagent:EqualStmt openpolicyagent:IsArrayStmt openpolicyagent:IsDefinedStmt openpolicyagent:IsObjectStmt openpolicyagent:IsSetStmt openpolicyagent:IsUndefinedStmt openpolicyagent:LenStmt openpolicyagent:MakeArrayStmt openpolicyagent:MakeNullStmt openpolicyagent:MakeNumberIntStmt openpolicyagent:MakeNumberRefStmt openpolicyagent:MakeObjectStmt openpolicyagent:MakeSetStmt openpolicyagent:NopStmt openpolicyagent:NotEqualStmt openpolicyagent:NotStmt openpolicyagent:ObjectInsertOnceStmt openpolicyagent:ObjectInsertStmt openpolicyagent:ObjectMergeStmt openpolicyagent:ResetLocalStmt openpolicyagent:ResultSetAddStmt openpolicyagent:ReturnLocalStmt openpolicyagent:ScanStmt openpolicyagent:SetAddStmt openpolicyagent:WithStmt ) ] openpolicyagent:Any ) ] ;
