@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix linkml: <https://w3id.org/linkml/> .
@prefix openpolicyagent: <https://w3id.org/lmodel/opa/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pav: <http://purl.org/pav/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://w3id.org/lmodel/opa.owl.ttl> a owl:Ontology ;
    rdfs:label "opa" ;
    dcterms:license "Apache-2.0" ;
    dcterms:source <https://github.com/open-policy-agent/opa/blob/main> ;
    dcterms:title "Open Policy Agent (OPA)" ;
    pav:version "0.1.0" ;
    rdfs:seeAlso <https://lmodel.github.io/opa>,
        <https://www.openpolicyagent.org/> ;
    skos:definition "Umbrella LinkML schema for Open Policy Agent (OPA) and the Rego policy language. Imports per-source submodules generated from upstream OPA artifacts (capabilities, built-in metadata, version index, sample authorization input, bundle manifest, and IR plan)." .

openpolicyagent:AuthorizationInput a owl:Class ;
    rdfs:label "AuthorizationInput" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty openpolicyagent:identity ],
        [ a owl:Restriction ;
            owl:allValuesFrom openpolicyagent:Any ;
            owl:onProperty openpolicyagent:body ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty openpolicyagent:identity ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty openpolicyagent:method ],
        [ a owl:Restriction ;
            owl:allValuesFrom openpolicyagent:Any ;
            owl:onProperty openpolicyagent:params ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty openpolicyagent:headers ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty openpolicyagent:body ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty openpolicyagent:params ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty openpolicyagent:method ],
        [ a owl:Restriction ;
            owl:allValuesFrom openpolicyagent:Any ;
            owl:onProperty openpolicyagent:client_certificates ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty openpolicyagent:client_certificates ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty openpolicyagent:method ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty openpolicyagent:headers ],
        [ a owl:Restriction ;
            owl:allValuesFrom openpolicyagent:Any ;
            owl:onProperty openpolicyagent:headers ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty openpolicyagent:path ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty openpolicyagent:params ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty openpolicyagent:identity ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty openpolicyagent:path ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty openpolicyagent:body ] ;
    skos:closeMatch <https://w3id.org/lmodel/d3fend/Authorization>,
        <https://w3id.org/lmodel/dpv/AuthorisationProcedure> ;
    skos:definition "Input document the example HTTP API Authorization policy receives. Mirrors the OPA-provided JSON Schema at ``v1/schemas/authorizationPolicy.json``." ;
    skos:inScheme openpolicyagent:authorization_input ;
    skos:relatedMatch <https://w3id.org/lmodel/d3fend/AccessControlList>,
        <https://w3id.org/lmodel/d3fend/AuthorizationService>,
        <https://w3id.org/lmodel/dpv/Access>,
        <https://w3id.org/lmodel/iso27001/SecurityControl>,
        <https://w3id.org/lmodel/oscal/AuthorizationBoundary> .

openpolicyagent:BuiltinMetadataCatalog a owl:Class ;
    rdfs:label "BuiltinMetadataCatalog" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom openpolicyagent:BuiltinCategoryGroup ;
            owl:onProperty openpolicyagent:categories ],
        [ a owl:Restriction ;
            owl:allValuesFrom openpolicyagent:BuiltinMetadata ;
            owl:onProperty openpolicyagent:builtins ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty openpolicyagent:categories ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty openpolicyagent:builtins ] ;
    skos:broadMatch <https://w3id.org/lmodel/oscal/Catalog> ;
    skos:definition "Wrapper class for the contents of ``builtin_metadata.json``. The source document is a flat map keyed by built-in name plus a ``_categories`` map; the generator script reshapes it so ``categories`` and ``builtins`` are explicit, inlined-as-dict slots on this wrapper." ;
    skos:inScheme openpolicyagent:builtin_metadata ;
    skos:relatedMatch <https://w3id.org/lmodel/iso27001/ControlCategory> .

openpolicyagent:Capabilities a owl:Class ;
    rdfs:label "Capabilities" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty openpolicyagent:features ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty openpolicyagent:allow_net ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty openpolicyagent:wasm_abi_versions ],
        [ a owl:Restriction ;
            owl:allValuesFrom openpolicyagent:WasmABIVersion ;
            owl:onProperty openpolicyagent:wasm_abi_versions ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty openpolicyagent:allow_net ],
        [ a owl:Restriction ;
            owl:allValuesFrom openpolicyagent:Builtin ;
            owl:onProperty openpolicyagent:builtins ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty openpolicyagent:builtins ],
        [ a owl:Restriction ;
            owl:allValuesFrom openpolicyagent:FeatureName ;
            owl:onProperty openpolicyagent:features ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty openpolicyagent:future_keywords ],
        [ a owl:Restriction ;
            owl:allValuesFrom openpolicyagent:FutureKeyword ;
            owl:onProperty openpolicyagent:future_keywords ] ;
    skos:closeMatch <https://w3id.org/lmodel/oscal/Capability> ;
    skos:definition "Top-level capabilities document published by an OPA build. Lists every built-in function the runtime supports along with Wasm ABI compatibility, future keywords and feature flags." ;
    skos:inScheme openpolicyagent:capabilities ;
    skos:relatedMatch <https://w3id.org/lmodel/d3fend/LocalAuthorizationService> .

openpolicyagent:Manifest a owl:Class ;
    rdfs:label "Manifest" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty openpolicyagent:roots ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty openpolicyagent:metadata ],
        [ a owl:Restriction ;
            owl:allValuesFrom openpolicyagent:WasmResolver ;
            owl:onProperty openpolicyagent:wasm ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty openpolicyagent:wasm ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty openpolicyagent:revision ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:intersectionOf ( xsd:integer [ a rdfs:Datatype ;
                                owl:onDatatype xsd:integer ;
                                owl:withRestrictions ( [ xsd:minInclusive 0 ] ) ] [ a rdfs:Datatype ;
                                owl:onDatatype xsd:integer ;
                                owl:withRestrictions ( [ xsd:maxInclusive 1 ] ) ] ) ] ;
            owl:onProperty openpolicyagent:rego_version ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty openpolicyagent:roots ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty openpolicyagent:revision ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty openpolicyagent:file_rego_versions ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty openpolicyagent:rego_version ],
        [ a owl:Restriction ;
            owl:allValuesFrom openpolicyagent:Any ;
            owl:onProperty openpolicyagent:metadata ],
        [ a owl:Restriction ;
            owl:allValuesFrom openpolicyagent:FileRegoVersion ;
            owl:onProperty openpolicyagent:file_rego_versions ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty openpolicyagent:revision ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty openpolicyagent:rego_version ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty openpolicyagent:metadata ] ;
    skos:broadMatch <https://w3id.org/lmodel/d3fend/AccessControlConfiguration>,
        <https://w3id.org/lmodel/dpv/Policy>,
        <https://w3id.org/lmodel/iso27001/DocumentedInformation>,
        <https://w3id.org/lmodel/oscal/ComponentDefinition>,
        <https://w3id.org/lmodel/slsa/ResourceDescriptor> ;
    skos:closeMatch <https://w3id.org/lmodel/oscal/DefinedComponent>,
        <https://w3id.org/lmodel/slsa/Statement> ;
    skos:definition "``Manifest`` definition from upstream JSON Schema." ;
    skos:inScheme openpolicyagent:bundle_manifest ;
    skos:relatedMatch <https://w3id.org/lmodel/slsa/BuildProvenance>,
        <https://w3id.org/lmodel/slsa/DigestSet>,
        <https://w3id.org/lmodel/slsa/VerificationSummaryAttestation> .

openpolicyagent:Policy a owl:Class ;
    rdfs:label "Policy" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty openpolicyagent:funcs ],
        [ a owl:Restriction ;
            owl:allValuesFrom openpolicyagent:Plans ;
            owl:onProperty openpolicyagent:plans ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty openpolicyagent:static ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty openpolicyagent:plans ],
        [ a owl:Restriction ;
            owl:allValuesFrom openpolicyagent:Funcs ;
            owl:onProperty openpolicyagent:funcs ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty openpolicyagent:plans ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty openpolicyagent:static ],
        [ a owl:Restriction ;
            owl:allValuesFrom openpolicyagent:Static ;
            owl:onProperty openpolicyagent:static ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty openpolicyagent:funcs ] ;
    skos:closeMatch <https://w3id.org/lmodel/d3fend/AccessControlConfiguration>,
        <https://w3id.org/lmodel/dpv/Policy>,
        <https://w3id.org/lmodel/iso27001/InformationSecurityPolicy>,
        <https://w3id.org/lmodel/iso27001/TopicSpecificPolicy> ;
    skos:definition "``Policy`` definition from upstream JSON Schema." ;
    skos:inScheme openpolicyagent:ir_plan ;
    skos:relatedMatch <https://w3id.org/lmodel/d3fend/ContentPolicy>,
        <https://w3id.org/lmodel/d3fend/ControlFlowPolicy>,
        <https://w3id.org/lmodel/dpv/AccessControlMethod>,
        <https://w3id.org/lmodel/oscal/Profile>,
        <https://w3id.org/lmodel/slsa/Package> .

openpolicyagent:VersionIndex a owl:Class ;
    rdfs:label "VersionIndex" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty openpolicyagent:features ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty openpolicyagent:keywords ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty openpolicyagent:builtins ],
        [ a owl:Restriction ;
            owl:allValuesFrom openpolicyagent:ElementVersion ;
            owl:onProperty openpolicyagent:keywords ],
        [ a owl:Restriction ;
            owl:allValuesFrom openpolicyagent:ElementVersion ;
            owl:onProperty openpolicyagent:builtins ],
        [ a owl:Restriction ;
            owl:allValuesFrom openpolicyagent:ElementVersion ;
            owl:onProperty openpolicyagent:features ] ;
    skos:definition "Mapping from language-element names to the OPA semantic version that first introduced them. Grouped into built-ins, future-keywords, and features." ;
    skos:inScheme openpolicyagent:version_index .

openpolicyagent:ArrayAppendStmt a owl:Class ;
    rdfs:label "ArrayAppendStmt" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty openpolicyagent:file ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty openpolicyagent:col ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:integer ;
            owl:onProperty openpolicyagent:file ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty openpolicyagent:file ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty openpolicyagent:row ],
        [ a owl:Restriction ;
            owl:allValuesFrom openpolicyagent:Operand ;
            owl:onProperty openpolicyagent:value ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty openpolicyagent:row ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:integer ;
            owl:onProperty openpolicyagent:array ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty openpolicyagent:array ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty openpolicyagent:col ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty openpolicyagent:value ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty openpolicyagent:array ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:integer ;
            owl:onProperty openpolicyagent:col ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty openpolicyagent:value ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:integer ;
            owl:onProperty openpolicyagent:row ] ;
    skos:definition "``ArrayAppendStmt`` definition from upstream JSON Schema." ;
    skos:inScheme openpolicyagent:ir_plan .

openpolicyagent:AssignIntStmt a owl:Class ;
    rdfs:label "AssignIntStmt" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:integer ;
            owl:onProperty openpolicyagent:value ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty openpolicyagent:row ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty openpolicyagent:col ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:integer ;
            owl:onProperty openpolicyagent:row ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty openpolicyagent:file ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty openpolicyagent:row ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty openpolicyagent:target ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:integer ;
            owl:onProperty openpolicyagent:file ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty openpolicyagent:value ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty openpolicyagent:value ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty openpolicyagent:col ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:integer ;
            owl:onProperty openpolicyagent:col ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty openpolicyagent:file ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty openpolicyagent:target ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:integer ;
            owl:onProperty openpolicyagent:target ] ;
    skos:definition "``AssignIntStmt`` definition from upstream JSON Schema." ;
    skos:inScheme openpolicyagent:ir_plan .

openpolicyagent:AssignVarOnceStmt a owl:Class ;
    rdfs:label "AssignVarOnceStmt" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty openpolicyagent:col ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty openpolicyagent:row ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:integer ;
            owl:onProperty openpolicyagent:file ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty openpolicyagent:col ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:integer ;
            owl:onProperty openpolicyagent:target ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty openpolicyagent:source ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty openpolicyagent:target ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty openpolicyagent:target ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty openpolicyagent:file ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty openpolicyagent:file ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:integer ;
            owl:onProperty openpolicyagent:col ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty openpolicyagent:row ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:integer ;
            owl:onProperty openpolicyagent:row ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty openpolicyagent:source ],
        [ a owl:Restriction ;
            owl:allValuesFrom openpolicyagent:Operand ;
            owl:onProperty openpolicyagent:source ] ;
    skos:definition "``AssignVarOnceStmt`` definition from upstream JSON Schema." ;
    skos:inScheme openpolicyagent:ir_plan .

openpolicyagent:AssignVarStmt a owl:Class ;
    rdfs:label "AssignVarStmt" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty openpolicyagent:file ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:integer ;
            owl:onProperty openpolicyagent:row ],
        [ a owl:Restriction ;
