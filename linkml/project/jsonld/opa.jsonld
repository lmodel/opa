    {
      "name": "Stmt",
      "definition_uri": "https://w3id.org/lmodel/opa/Stmt",
      "description": "Tagged-wrapper class for the ``Stmt`` discriminated union from\nthe upstream JSON Schema.\n\nThe ``type`` slot carries the discriminator tag and the\n``stmt`` slot carries the typed payload. Because the\npayload class varies by tag, ``stmt`` is typed as\n``Any`` with an ``any_of`` union over the known payload classes;\nconsumers select the concrete class using the table below.\n\n* ``ArrayAppendStmt`` -- payload class ``ArrayAppendStmt``\n* ``AssignIntStmt`` -- payload class ``AssignIntStmt``\n* ``AssignVarOnceStmt`` -- payload class ``AssignVarOnceStmt``\n* ``AssignVarStmt`` -- payload class ``AssignVarStmt``\n* ``BlockStmt`` -- payload class ``BlockStmt``\n* ``BreakStmt`` -- payload class ``BreakStmt``\n* ``CallDynamicStmt`` -- payload class ``CallDynamicStmt``\n* ``CallStmt`` -- payload class ``CallStmt``\n* ``DotStmt`` -- payload class ``DotStmt``\n* ``EqualStmt`` -- payload class ``EqualStmt``\n* ``IsArrayStmt`` -- payload class ``IsArrayStmt``\n* ``IsDefinedStmt`` -- payload class ``IsDefinedStmt``\n* ``IsObjectStmt`` -- payload class ``IsObjectStmt``\n* ``IsSetStmt`` -- payload class ``IsSetStmt``\n* ``IsUndefinedStmt`` -- payload class ``IsUndefinedStmt``\n* ``LenStmt`` -- payload class ``LenStmt``\n* ``MakeArrayStmt`` -- payload class ``MakeArrayStmt``\n* ``MakeNullStmt`` -- payload class ``MakeNullStmt``\n* ``MakeNumberIntStmt`` -- payload class ``MakeNumberIntStmt``\n* ``MakeNumberRefStmt`` -- payload class ``MakeNumberRefStmt``\n* ``MakeObjectStmt`` -- payload class ``MakeObjectStmt``\n* ``MakeSetStmt`` -- payload class ``MakeSetStmt``\n* ``NopStmt`` -- payload class ``NopStmt``\n* ``NotEqualStmt`` -- payload class ``NotEqualStmt``\n* ``NotStmt`` -- payload class ``NotStmt``\n* ``ObjectInsertOnceStmt`` -- payload class ``ObjectInsertOnceStmt``\n* ``ObjectInsertStmt`` -- payload class ``ObjectInsertStmt``\n* ``ObjectMergeStmt`` -- payload class ``ObjectMergeStmt``\n* ``ResetLocalStmt`` -- payload class ``ResetLocalStmt``\n* ``ResultSetAddStmt`` -- payload class ``ResultSetAddStmt``\n* ``ReturnLocalStmt`` -- payload class ``ReturnLocalStmt``\n* ``ScanStmt`` -- payload class ``ScanStmt``\n* ``SetAddStmt`` -- payload class ``SetAddStmt``\n* ``WithStmt`` -- payload class ``WithStmt``",
      "in_subset": [
        "ir_plan_supporting_elements"
      ],
      "from_schema": "https://w3id.org/lmodel/opa/ir_plan",
      "slots": [
        "stmt__type",
        "stmt__stmt"
      ],
      "slot_usage": {},
      "attributes": [
        {
          "name": "type",
          "description": "Discriminator tag identifying the Stmt variant.",
          "range": "StmtTag",
          "required": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "stmt",
          "description": "Typed payload; concrete class is selected by ``type``.",
          "range": "Any",
          "required": true,
          "inlined": true,
          "any_of": [
            {
              "range": "ArrayAppendStmt",
              "@type": "AnonymousSlotExpression"
            },
            {
              "range": "AssignIntStmt",
              "@type": "AnonymousSlotExpression"
            },
            {
              "range": "AssignVarOnceStmt",
              "@type": "AnonymousSlotExpression"
            },
            {
              "range": "AssignVarStmt",
              "@type": "AnonymousSlotExpression"
            },
            {
              "range": "BlockStmt",
              "@type": "AnonymousSlotExpression"
            },
            {
              "range": "BreakStmt",
              "@type": "AnonymousSlotExpression"
            },
            {
              "range": "CallDynamicStmt",
              "@type": "AnonymousSlotExpression"
            },
            {
              "range": "CallStmt",
              "@type": "AnonymousSlotExpression"
            },
            {
              "range": "DotStmt",
              "@type": "AnonymousSlotExpression"
            },
            {
              "range": "EqualStmt",
              "@type": "AnonymousSlotExpression"
            },
            {
              "range": "IsArrayStmt",
              "@type": "AnonymousSlotExpression"
            },
            {
              "range": "IsDefinedStmt",
              "@type": "AnonymousSlotExpression"
            },
            {
              "range": "IsObjectStmt",
              "@type": "AnonymousSlotExpression"
            },
            {
              "range": "IsSetStmt",
              "@type": "AnonymousSlotExpression"
            },
            {
              "range": "IsUndefinedStmt",
              "@type": "AnonymousSlotExpression"
            },
            {
              "range": "LenStmt",
              "@type": "AnonymousSlotExpression"
            },
            {
              "range": "MakeArrayStmt",
              "@type": "AnonymousSlotExpression"
            },
            {
              "range": "MakeNullStmt",
              "@type": "AnonymousSlotExpression"
            },
            {
              "range": "MakeNumberIntStmt",
              "@type": "AnonymousSlotExpression"
            },
            {
              "range": "MakeNumberRefStmt",
              "@type": "AnonymousSlotExpression"
            },
            {
              "range": "MakeObjectStmt",
              "@type": "AnonymousSlotExpression"
            },
            {
              "range": "MakeSetStmt",
              "@type": "AnonymousSlotExpression"
            },
            {
              "range": "NopStmt",
              "@type": "AnonymousSlotExpression"
            },
            {
              "range": "NotEqualStmt",
              "@type": "AnonymousSlotExpression"
            },
            {
              "range": "NotStmt",
              "@type": "AnonymousSlotExpression"
            },
            {
              "range": "ObjectInsertOnceStmt",
              "@type": "AnonymousSlotExpression"
            },
            {
              "range": "ObjectInsertStmt",
              "@type": "AnonymousSlotExpression"
            },
            {
              "range": "ObjectMergeStmt",
              "@type": "AnonymousSlotExpression"
            },
            {
              "range": "ResetLocalStmt",
              "@type": "AnonymousSlotExpression"
            },
            {
              "range": "ResultSetAddStmt",
              "@type": "AnonymousSlotExpression"
            },
            {
              "range": "ReturnLocalStmt",
              "@type": "AnonymousSlotExpression"
            },
            {
              "range": "ScanStmt",
              "@type": "AnonymousSlotExpression"
            },
