        {
          "name": "builtins",
          "description": "All documented built-ins keyed by name.",
          "range": "BuiltinMetadata",
          "multivalued": true,
          "inlined": true,
          "@type": "SlotDefinition"
        }
      ],
      "class_uri": "https://w3id.org/lmodel/opa/BuiltinMetadataCatalog",
      "tree_root": true,
