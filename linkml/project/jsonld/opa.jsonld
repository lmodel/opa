        "builtinMetadata__result"
      ],
      "slot_usage": {},
      "attributes": [
        {
          "name": "name",
          "description": "Built-in identifier (dotted path).",
          "exact_mappings": [
            "schema:identifier",
            "dcterms:identifier"
          ],
          "identifier": true,
          "range": "string",
          "required": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "description",
          "description": "Markdown description of the built-in.",
          "slot_uri": "schema:description",
          "range": "string",
          "@type": "SlotDefinition"
        },
        {
          "name": "introduced",
          "description": "Earliest OPA release tag in which the built-in was available.",
          "range": "string",
          "@type": "SlotDefinition"
        },
        {
          "name": "available",
          "description": "Every OPA release tag in which the built-in is available.",
          "range": "string",
          "multivalued": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "wasm",
          "description": "True if the built-in is implemented for the Wasm target.",
          "range": "boolean",
          "@type": "SlotDefinition"
        },
        {
          "name": "infix",
          "description": "Optional infix operator symbol.",
          "range": "string",
          "@type": "SlotDefinition"
        },
        {
          "name": "deprecated",
          "description": "True when the built-in is scheduled for removal.",
          "range": "boolean",
          "@type": "SlotDefinition"
        },
        {
          "name": "relation",
          "description": "True when the built-in is a relation.",
          "range": "boolean",
          "@type": "SlotDefinition"
        },
        {
          "name": "args",
          "description": "Positional argument descriptors in declaration order.",
          "range": "BuiltinArg",
          "multivalued": true,
          "inlined": true,
          "inlined_as_list": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "result",
          "description": "Descriptor for the value returned by the built-in.",
          "range": "BuiltinResult",
          "inlined": true,
          "@type": "SlotDefinition"
