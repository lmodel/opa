          "name": "type",
          "description": "Discriminator tag identifying the Val variant.",
          "range": "ValTag",
          "required": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "value",
          "description": "Typed payload; concrete class is selected by ``type``.",
          "range": "Any",
          "required": true,
          "inlined": true,
          "any_of": [
