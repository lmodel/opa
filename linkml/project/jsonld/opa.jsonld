          "identifier": true,
          "range": "string",
          "required": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "category",
          "description": "Same value as ``name``, typed against the BuiltinCategory enum for downstream consumers.",
          "range": "BuiltinCategory",
          "@type": "SlotDefinition"
        },
        {
          "name": "builtins",
          "description": "Names of the built-ins belonging to this category.",
          "range": "string",
          "required": true,
          "multivalued": true,
          "@type": "SlotDefinition"
        }
      ],
      "class_uri": "https://w3id.org/lmodel/opa/BuiltinCategoryGroup",
      "@type": "ClassDefinition"
    },
    {
      "name": "BuiltinMetadata",
