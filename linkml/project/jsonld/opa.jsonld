    {
      "name": "BuiltinMetadataCatalog",
      "definition_uri": "https://w3id.org/lmodel/opa/BuiltinMetadataCatalog",
      "description": "Wrapper class for the contents of ``builtin_metadata.json``. The source document is a flat map keyed by built-in name plus a ``_categories`` map; the generator script reshapes it so ``categories`` and ``builtins`` are explicit, inlined-as-dict slots on this wrapper.",
      "in_subset": [
