  "classes": [
    {
      "name": "Any",
      "definition_uri": "https://w3id.org/lmodel/opa/Any",
      "description": "Free-form value placeholder (scalar, list, or object). Used to model source slots whose representation is heterogeneous or intentionally open (e.g. ``TypeDecl.key``, ``AuthorizationInput.body``).",
      "comments": [
        "Single shared definition mapped to ``linkml:Any`` (per metamodel) to avoid duplicate-class collisions across imported modules.",
        "Usage is concentrated at real polymorphism boundaries: free-form HTTP payloads, bundle metadata/annotations, discriminated-union payloads, and upstream-opaque JSON Schema slots.",
        "Usage is localized (roughly 11 sites across ~60 classes); most slots remain explicitly typed rather than defaulting to ``Any``."
      ],
      "in_subset": [
        "common_supporting_elements"
      ],
      "from_schema": "https://w3id.org/lmodel/opa/common",
      "mappings": [
        "linkml:Any"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/linkml/Any",
      "@type": "ClassDefinition"
    },
    {
      "name": "Capabilities",
      "definition_uri": "https://w3id.org/lmodel/opa/Capabilities",
      "description": "Top-level capabilities document published by an OPA build. Lists every built-in function the runtime supports along with Wasm ABI compatibility, future keywords and feature flags.",
      "in_subset": [
        "capabilities_core_elements"
      ],
      "from_schema": "https://w3id.org/lmodel/opa/capabilities",
      "close_mappings": [
        "oscal:Capability"
      ],
      "related_mappings": [
        "d3fend:LocalAuthorizationService"
      ],
      "slots": [
        "capabilities__builtins",
        "capabilities__future_keywords",
        "capabilities__wasm_abi_versions",
        "capabilities__features",
        "capabilities__allow_net"
      ],
      "slot_usage": {},
      "attributes": [
        {
          "name": "builtins",
          "description": "All built-in functions supported by this OPA build.",
          "range": "Builtin",
          "multivalued": true,
          "inlined": true,
          "inlined_as_list": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "future_keywords",
          "description": "Keywords reserved for future Rego releases.",
          "range": "FutureKeyword",
          "multivalued": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "wasm_abi_versions",
          "description": "Wasm ABI versions the runtime can host.",
          "range": "WasmABIVersion",
          "multivalued": true,
          "inlined": true,
          "inlined_as_list": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "features",
          "description": "Optional language / runtime features enabled in this build.",
          "range": "FeatureName",
          "multivalued": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "allow_net",
          "description": "Network destinations the built-ins are allowed to contact. Absent or empty means unrestricted; an empty list means no network access.",
          "range": "string",
          "multivalued": true,
          "@type": "SlotDefinition"
        }
      ],
      "class_uri": "https://w3id.org/lmodel/opa/Capabilities",
      "tree_root": true,
      "@type": "ClassDefinition"
    },
    {
      "name": "Builtin",
      "definition_uri": "https://w3id.org/lmodel/opa/Builtin",
      "description": "A Rego built-in function exposed by the OPA runtime.",
      "in_subset": [
        "capabilities_supporting_elements"
      ],
      "from_schema": "https://w3id.org/lmodel/opa/capabilities",
      "related_mappings": [
        "d3fend:AccessPolicyAdministration",
        "oscal:Control"
      ],
      "slots": [
        "builtin__name",
        "builtin__decl",
        "builtin__infix",
        "builtin__deprecated",
        "builtin__nondeterministic",
        "builtin__relation"
      ],
      "slot_usage": {},
      "attributes": [
        {
          "name": "name",
          "description": "Built-in identifier (dotted path, e.g. ``array.concat``).",
          "exact_mappings": [
            "schema:identifier",
            "dcterms:identifier"
          ],
          "identifier": true,
          "range": "string",
          "required": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "decl",
          "description": "Type declaration: signature plus return type.",
          "range": "BuiltinDecl",
          "required": true,
          "inlined": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "infix",
          "description": "Optional infix operator symbol (e.g. ``&``, ``==``).",
          "range": "string",
          "@type": "SlotDefinition"
        },
        {
          "name": "deprecated",
          "description": "True when the built-in is scheduled for removal.",
          "range": "boolean",
          "@type": "SlotDefinition"
        },
        {
          "name": "nondeterministic",
          "description": "True when invocations may produce different results across runs.",
          "range": "boolean",
          "@type": "SlotDefinition"
        },
        {
          "name": "relation",
          "description": "True when the built-in is a relation (binds output variables).",
          "range": "boolean",
          "@type": "SlotDefinition"
        }
      ],
      "class_uri": "https://w3id.org/lmodel/opa/Builtin",
      "@type": "ClassDefinition"
    },
    {
      "name": "BuiltinDecl",
      "definition_uri": "https://w3id.org/lmodel/opa/BuiltinDecl",
      "description": "Type declaration of a built-in: function signature and return type.",
      "in_subset": [
        "capabilities_supporting_elements"
      ],
      "from_schema": "https://w3id.org/lmodel/opa/capabilities",
      "related_mappings": [
        "d3fend:AccessPolicyAdministration"
      ],
      "slots": [
        "builtinDecl__type",
        "builtinDecl__args",
        "builtinDecl__result",
        "builtinDecl__variadic"
      ],
      "slot_usage": {},
      "attributes": [
        {
          "name": "type",
          "description": "Always the literal string ``function``.",
          "range": "string",
          "required": true,
          "equals_string": "function",
          "@type": "SlotDefinition"
        },
        {
          "name": "args",
          "description": "Positional argument types in declaration order.",
          "range": "TypeDecl",
          "multivalued": true,
          "inlined": true,
          "inlined_as_list": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "result",
          "description": "Type of the result returned by the built-in.",
          "range": "TypeDecl",
          "inlined": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "variadic",
          "description": "When present, indicates the built-in accepts any number of trailing arguments of this type.",
          "range": "TypeDecl",
          "inlined": true,
          "@type": "SlotDefinition"
        }
      ],
      "class_uri": "https://w3id.org/lmodel/opa/BuiltinDecl",
      "@type": "ClassDefinition"
    },
    {
      "name": "TypeDecl",
      "definition_uri": "https://w3id.org/lmodel/opa/TypeDecl",
      "description": "Recursive type expression used throughout Capabilities declarations.\n\nAll slots are optional because TypeDecl doubles as the structural envelope\nfor the various heterogeneous shapes the source JSON uses:\n* ``string|number|boolean|null|function`` -- atomic; only ``type`` is set.\n* ``any`` -- ``of`` is a list of alternative TypeDecls.\n* ``set`` -- ``of`` holds the (single) element TypeDecl.\n* ``array`` -- ``dynamic`` is the homogeneous element TypeDecl, or\n  ``static`` is an ordered list describing a fixed-length tuple.\n* ``object`` -- ``static`` lists named property pairs (TypeDecls with\n  ``key`` and ``value`` populated); ``dynamic`` is a TypeDecl whose\n  ``key``/``value`` describe additional property typing.\n* Inside an ``object``'s ``dynamic`` value, the TypeDecl has only\n  ``key`` and ``value`` populated -- ``type`` is absent.\n",
      "in_subset": [
        "capabilities_supporting_elements"
      ],
      "from_schema": "https://w3id.org/lmodel/opa/capabilities",
      "slots": [
        "typeDecl__type",
        "typeDecl__of",
        "typeDecl__dynamic",
        "typeDecl__static",
        "typeDecl__key",
        "typeDecl__value"
      ],
      "slot_usage": {},
      "attributes": [
        {
          "name": "type",
          "description": "Discriminator: the kind of value this TypeDecl describes.",
          "range": "BuiltinTypeKind",
          "@type": "SlotDefinition"
        },
        {
          "name": "of",
          "description": "Element type(s). For ``set`` it is the (single) element type; for ``any`` it is a union of alternative types. Always represented as a list -- the instance generator wraps source scalar values for shape uniformity.",
          "range": "TypeDecl",
          "multivalued": true,
          "inlined": true,
          "inlined_as_list": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "dynamic",
          "description": "For ``array`` types this is the element TypeDecl; for ``object`` types it is a TypeDecl with ``key`` and ``value`` populated.",
          "range": "TypeDecl",
          "inlined": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "static",
          "description": "Either named property pairs of an ``object`` TypeDecl (each entry has ``key`` and ``value`` populated) or positional tuple element TypeDecls of a fixed-length ``array`` TypeDecl. Same recursive TypeDecl shape.",
          "range": "TypeDecl",
          "multivalued": true,
          "inlined": true,
          "inlined_as_list": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "key",
          "description": "Key of an object's dynamic-property mapping or static-property entry. When the parent TypeDecl is an object's ``dynamic`` slot, this is itself a TypeDecl (e.g. ``{type: string}``); when the parent is an object's ``static`` entry, it is a string literal naming the property.",
          "range": "Any",
          "inlined": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "value",
          "description": "Value type of an object's dynamic property mapping or static property entry. Always a TypeDecl.",
          "range": "TypeDecl",
          "inlined": true,
          "@type": "SlotDefinition"
        }
      ],
      "class_uri": "https://w3id.org/lmodel/opa/TypeDecl",
      "@type": "ClassDefinition"
    },
    {
      "name": "WasmABIVersion",
      "definition_uri": "https://w3id.org/lmodel/opa/WasmABIVersion",
      "description": "A supported Wasm ABI version pair.",
      "in_subset": [
